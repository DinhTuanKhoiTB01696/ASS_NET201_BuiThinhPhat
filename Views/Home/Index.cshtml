@model IEnumerable<Assignment_NET201.Models.Product>
@{
    ViewData["Title"] = "Home";
}

<style>
    /* ========== HERO CAROUSEL ========== */
    .hero-carousel { position: relative; overflow: hidden; }
    .hero-carousel .carousel-item { transition: transform 0.8s ease-in-out; }
    .hero-carousel .carousel-item img { filter: brightness(0.82); transition: transform 8s ease-out; }
    .hero-carousel .carousel-item.active img { transform: scale(1.05); }

    .hero-overlay {
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.15) 55%, rgba(0,0,0,0.35) 100%);
        z-index: 1;
    }

    .hero-carousel .carousel-caption { z-index: 2; bottom: 15%; }

    .hero-carousel .carousel-item.active .hero-title { animation: slideInDown 0.8s ease-out forwards; }
    .hero-carousel .carousel-item.active .hero-subtitle { animation: fadeInUp 0.8s ease-out 0.3s forwards; opacity: 0; }
    .hero-carousel .carousel-item.active .hero-btn { animation: fadeInUp 0.8s ease-out 0.5s forwards; opacity: 0; }

    @@keyframes slideInDown { from { opacity:0; transform:translateY(-30px); } to { opacity:1; transform:translateY(0); } }
    @@keyframes fadeInUp    { from { opacity:0; transform:translateY(30px);  } to { opacity:1; transform:translateY(0); } }

    .hero-carousel .carousel-indicators { bottom: 30px; z-index: 3; }
    .hero-carousel .carousel-indicators button {
        width: 12px; height: 12px; border-radius: 50%;
        background: rgba(255,255,255,0.4); border: 2px solid rgba(255,255,255,0.6);
        margin: 0 6px; transition: all 0.4s ease;
    }
    .hero-carousel .carousel-indicators button.active {
        width: 40px; border-radius: 20px;
        background: rgba(255,255,255,0.9); border-color: #fff;
    }

    .hero-carousel .carousel-control-prev,
    .hero-carousel .carousel-control-next {
        width: 56px; height: 56px; top: 50%; transform: translateY(-50%);
        background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);
        border-radius: 50%; opacity: 0; transition: all 0.4s ease; z-index: 3;
    }
    .hero-carousel .carousel-control-prev { left: 30px; }
    .hero-carousel .carousel-control-next { right: 30px; }
    .hero-carousel:hover .carousel-control-prev,
    .hero-carousel:hover .carousel-control-next { opacity: 1; }
    .hero-carousel .carousel-control-prev:hover,
    .hero-carousel .carousel-control-next:hover {
        background: rgba(255,255,255,0.28); transform: translateY(-50%) scale(1.1);
    }

    .btn-hero-primary {
        background: linear-gradient(135deg, #1a1a1a 0%, #3d3d3d 100%);
        border: none; color: #fff; padding: 15px 40px;
        font-weight: 700; text-transform: uppercase; letter-spacing: 2px;
        position: relative; overflow: hidden; transition: all 0.4s ease;
        border-radius: 2px;
    }
    .btn-hero-primary::before {
        content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
        transition: left 0.6s ease;
    }
    .btn-hero-primary:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(0,0,0,0.3); color: #fff; }
    .btn-hero-primary:hover::before { left: 100%; }

    .btn-hero-outline {
        background: transparent; border: 2px solid rgba(255,255,255,0.85);
        color: #fff; padding: 13px 38px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 2px;
        backdrop-filter: blur(5px); transition: all 0.4s ease; border-radius: 2px;
    }
    .btn-hero-outline:hover {
        background: #fff; color: #1a1a1a;
        transform: translateY(-3px); box-shadow: 0 15px 40px rgba(255,255,255,0.25);
    }

    .hero-title {
        font-family: 'Anton', sans-serif; font-size: 4.5rem;
        letter-spacing: 4px; text-shadow: 3px 3px 20px rgba(0,0,0,0.5);
        background: linear-gradient(to right, #fff, #e0e0e0);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-subtitle { font-size: 1.2rem; letter-spacing: 1px; text-shadow: 1px 1px 10px rgba(0,0,0,0.5); }

    @@media (max-width: 768px) {
        .hero-title { font-size: 2.5rem; }
        .hero-carousel .carousel-control-prev,
        .hero-carousel .carousel-control-next { display: none; }
    }

    /* ========== SECTION HEADER ========== */
    .section-header { text-align: center; margin-bottom: 3.5rem; }
    .section-header h2 {
        font-family: 'Anton', sans-serif; font-size: 2.4rem;
        letter-spacing: 3px; color: #0f172a; margin-bottom: 0.75rem;
    }
    .section-divider {
        display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 0.5rem;
    }
    .section-divider::before,
    .section-divider::after {
        content: ''; height: 1px; width: 60px; background: #d1d5db;
    }
    .section-divider span {
        width: 8px; height: 8px; border-radius: 50%; background: #0f172a;
        display: inline-block;
    }

    /* ========== PRODUCT CARD ========== */
    .product-card-wrap {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .product-card-wrap.revealed {
        opacity: 1;
        transform: translateY(0);
    }

    .product-card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        transition: box-shadow 0.4s ease, transform 0.4s ease;
        position: relative;
    }
    .product-card:hover {
        box-shadow: 0 16px 48px rgba(0,0,0,0.14);
        transform: translateY(-6px);
    }

    /* Image container */
    .product-img-wrap {
        position: relative;
        overflow: hidden;
        background: #f8f9fa;
    }
    .product-img-wrap img {
        width: 100%; height: 320px; object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
        display: block;
    }
    .product-card:hover .product-img-wrap img {
        transform: scale(1.08);
    }

    /* Overlay on hover */
    .product-overlay {
        position: absolute; inset: 0;
        background: rgba(0,0,0,0.35);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: opacity 0.4s ease;
    }
    .product-card:hover .product-overlay { opacity: 1; }

    .btn-quick-view {
        background: #fff; color: #0f172a;
        border: none; padding: 11px 28px;
        font-weight: 700; font-size: 0.8rem; letter-spacing: 1.5px;
        text-transform: uppercase; border-radius: 2px;
        transform: translateY(12px); transition: transform 0.35s ease, background 0.25s ease, color 0.25s ease;
        text-decoration: none; cursor: pointer;
    }
    .product-card:hover .btn-quick-view { transform: translateY(0); }
    .btn-quick-view:hover { background: #0f172a; color: #fff; }

    /* Badges */
    .product-badge {
        position: absolute; top: 14px; left: 14px;
        z-index: 2; display: flex; flex-direction: column; gap: 6px;
    }
    .badge-tag {
        display: inline-block; padding: 4px 10px;
        font-size: 0.7rem; font-weight: 700; letter-spacing: 1px;
        border-radius: 3px; text-transform: uppercase;
    }
    .badge-hot   { background: #ef4444; color: #fff; }
    .badge-new   { background: #0f172a; color: #fff; }
    .badge-sale  { background: #f59e0b; color: #fff; }

    /* Wishlist icon */
    .btn-wishlist {
        position: absolute; top: 14px; right: 14px; z-index: 3;
        width: 36px; height: 36px; border-radius: 50%;
        background: rgba(255,255,255,0.9); border: none;
        display: flex; align-items: center; justify-content: center;
        color: #374151; font-size: 0.95rem;
        opacity: 0; transition: opacity 0.3s ease, color 0.25s ease, background 0.25s ease;
        text-decoration: none;
    }
    .product-card:hover .btn-wishlist { opacity: 1; }
    .btn-wishlist:hover { color: #ef4444; background: #fff; }

    /* Card body */
    .product-info { padding: 1.1rem 1.2rem 1.3rem; }
    .product-category-tag {
        font-size: 0.7rem; color: #9ca3af; letter-spacing: 1.5px;
        text-transform: uppercase; font-weight: 600; margin-bottom: 4px;
    }
    .product-name {
        font-size: 0.92rem; font-weight: 700; color: #0f172a;
        text-transform: uppercase; letter-spacing: 0.5px;
        text-decoration: none; line-height: 1.4;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .product-name:hover { color: #3b82f6; }
    .product-price {
        font-size: 1rem; font-weight: 700; color: #0f172a; margin-top: 6px;
    }

    /* Rating stars (decorative) */
    .product-stars { color: #f59e0b; font-size: 0.7rem; margin-top: 4px; }

    /* ========== VIEW ALL BUTTON ========== */
    .btn-view-all {
        display: inline-flex; align-items: center; gap: 10px;
        background: #0f172a; color: #fff;
        padding: 14px 48px; font-weight: 700;
        letter-spacing: 2px; text-transform: uppercase;
        text-decoration: none; border-radius: 2px;
        font-size: 0.85rem; transition: all 0.35s ease;
        position: relative; overflow: hidden;
    }
    .btn-view-all::before {
        content: ''; position: absolute; top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
        transition: left 0.6s ease;
    }
    .btn-view-all:hover { background: #1e293b; color: #fff; transform: translateY(-3px); box-shadow: 0 12px 32px rgba(15,23,42,0.25); }
    .btn-view-all:hover::before { left: 100%; }
    .btn-view-all i { transition: transform 0.3s ease; }
    .btn-view-all:hover i { transform: translateX(5px); }

    /* ========== COLLECTION BANNER ========== */
    .collection-banner { position: relative; overflow: hidden; }
    .collection-banner img {
        width: 100%; height: 500px; object-fit: cover;
        transition: transform 0.8s ease;
    }
    .collection-banner:hover img { transform: scale(1.04); }
    .collection-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.05) 60%);
    }
    .collection-content {
        position: absolute; bottom: 0; left: 0; padding: 2.5rem;
    }
    .collection-content h3 {
        color: #fff; font-family: 'Anton', sans-serif;
        font-size: 2rem; letter-spacing: 2px; margin-bottom: 0.75rem;
    }
    .btn-collection {
        display: inline-flex; align-items: center; gap: 8px;
        color: #fff; font-weight: 700; font-size: 0.8rem;
        letter-spacing: 2px; text-transform: uppercase;
        text-decoration: none; border-bottom: 2px solid rgba(255,255,255,0.6);
        padding-bottom: 3px; transition: all 0.3s ease;
    }
    .btn-collection:hover { color: #fff; border-color: #fff; padding-left: 8px; }

    /* ========== PROMO STRIP ========== */
    .promo-strip {
        background: #0f172a; color: #fff;
        padding: 18px 0; text-align: center;
        font-size: 0.85rem; font-weight: 600; letter-spacing: 2px;
        text-transform: uppercase;
    }
    .promo-strip span { margin: 0 24px; opacity: 0.85; }
    .promo-strip span + span::before { content: '⬥'; margin-right: 24px; opacity: 0.4; }

    /* ========== FEATURES BAR ========== */
    .features-bar { background: #fff; padding: 48px 0; border-top: 1px solid #f1f5f9; }
    .feature-item { text-align: center; padding: 0 1rem; }
    .feature-icon {
        width: 56px; height: 56px; border-radius: 50%;
        background: #f8fafc; display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem; font-size: 1.4rem; color: #0f172a;
        transition: all 0.3s ease;
    }
    .feature-item:hover .feature-icon { background: #0f172a; color: #fff; transform: scale(1.1); }
    .feature-item h6 { font-size: 0.85rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #0f172a; }
    .feature-item p { font-size: 0.78rem; color: #6b7280; margin: 0; }
</style>

<!-- Promo Strip -->
<div class="promo-strip">
    <span>Free shipping on orders over 500K</span>
    <span>New arrivals every week</span>
    <span>Easy 30-day returns</span>
</div>

<!-- Hero Carousel -->
<div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="5000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    </div>

    <div class="carousel-inner">
        <!-- Slide 1 -->
        <div class="carousel-item active">
            <div class="ratio ratio-21x9">
                <img src="~/images/banners/banner1.png" class="d-block w-100 object-fit-cover" alt="Streetwear Collection">
            </div>
            <div class="hero-overlay"></div>
            <div class="carousel-caption d-none d-md-block text-start" style="left:10%; right:auto; max-width:620px;">
                <h1 class="hero-title text-uppercase mb-3">ICONDENIM</h1>
                <p class="hero-subtitle text-white mb-4 opacity-90">Reimagining modern streetwear for the bold. Discover pieces that define your unique style.</p>
                <a asp-action="Shop" class="btn btn-hero-primary">
                    <i class="fas fa-shopping-bag me-2"></i>Shop Now
                </a>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item">
            <div class="ratio ratio-21x9">
                <img src="~/images/banners/banner2.png" class="d-block w-100 object-fit-cover" alt="Summer Collection">
            </div>
            <div class="hero-overlay"></div>
            <div class="carousel-caption d-none d-md-block text-end" style="right:10%; left:auto; max-width:620px;">
                <h1 class="hero-title text-uppercase mb-3">NEW ARRIVALS</h1>
                <p class="hero-subtitle text-white mb-4">Discover the latest trends for the season. Fresh styles, endless possibilities.</p>
                <a asp-action="Shop" class="btn btn-hero-outline">
                    <i class="fas fa-arrow-right me-2"></i>View Collection
                </a>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<!-- Best Sellers -->
<section class="py-5 mt-4" style="background: #f8fafc;">
    <div class="container">
        <div class="section-header">
            <h2 class="text-uppercase">Best Sellers</h2>
            <div class="section-divider"><span></span></div>
            <p class="text-muted mt-3" style="font-size:0.9rem; letter-spacing:0.5px;">Những sản phẩm được yêu thích nhất mùa này</p>
        </div>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
            @{int cardIndex = 0;}
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="product-card-wrap" style="transition-delay: @(cardIndex * 80)ms">
                        <div class="product-card h-100">

                            <!-- Image -->
                            <div class="product-img-wrap">
                                <a asp-action="ProductDetail" asp-route-id="@item.Id">
                                    <img src="@item.ImageUrl" alt="@item.Name" loading="lazy">
                                </a>

                                <!-- Overlay -->
                                <div class="product-overlay">
                                    <a asp-action="ProductDetail" asp-route-id="@item.Id" class="btn-quick-view">
                                        <i class="fas fa-eye me-2"></i>Quick View
                                    </a>
                                </div>

                                <!-- Badges -->
                                <div class="product-badge">
                                    @if (item.Price < 300000)
                                    {
                                        <span class="badge-tag badge-hot">Hot</span>
                                    }
                                    @if (cardIndex < 2)
                                    {
                                        <span class="badge-tag badge-new">New</span>
                                    }
                                </div>

                                <!-- Wishlist -->
                                <a asp-controller="Cart" asp-action="AddToWishlist" asp-route-productId="@item.Id"
                                   class="btn-wishlist" title="Add to wishlist">
                                    <i class="far fa-heart"></i>
                                </a>
                            </div>

                            <!-- Info -->
                            <div class="product-info">
                                <div class="product-category-tag">@(item.Category?.Name ?? "Fashion")</div>
                                <a asp-action="ProductDetail" asp-route-id="@item.Id" class="product-name d-block">
                                    @item.Name
                                </a>
                                <div class="product-stars">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star-half-alt"></i>
                                    <span class="text-muted ms-1" style="font-size:0.72rem;">(4.5)</span>
                                </div>
                                <div class="product-price">@item.Price.ToString("N0") <span style="font-size:0.75rem; font-weight:600; color:#6b7280;">VND</span></div>
                            </div>

                        </div>
                    </div>
                </div>
                cardIndex++;
            }
        </div>

        <!-- View All -->
        <div class="text-center mt-5 pt-2">
            <a asp-action="Shop" class="btn-view-all">
                View All Products <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
</section>

<!-- Collection Banner -->
<section class="container-fluid px-0 my-0">
    <div class="row g-0">
        <div class="col-md-6">
            <div class="collection-banner">
                <img src="/images/man-woman-basic-white-polo-shirts-apparel-studio-shoot.jpg" alt="Summer Collection">
                <div class="collection-overlay"></div>
                <div class="collection-content">
                    <h3 class="text-uppercase">Summer Collection</h3>
                    <a asp-action="Shop" class="btn-collection">
                        Discover <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="collection-banner">
                <img src="/images/man-basic-white-polo-shirt-apparel-studio-shoot.jpg" alt="Denim Culture">
                <div class="collection-overlay"></div>
                <div class="collection-content">
                    <h3 class="text-uppercase">Denim Culture</h3>
                    <a asp-action="Shop" class="btn-collection">
                        Explore <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Bar -->
<section class="features-bar">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="fas fa-shipping-fast"></i></div>
                    <h6>Free Shipping</h6>
                    <p>Orders over 500K</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="fas fa-undo-alt"></i></div>
                    <h6>Easy Returns</h6>
                    <p>30-day return policy</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                    <h6>Secure Payment</h6>
                    <p>100% safe checkout</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="fas fa-headset"></i></div>
                    <h6>24/7 Support</h6>
                    <p>Always here to help</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    // Scroll reveal for product cards
    const cards = document.querySelectorAll('.product-card-wrap');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.12 });

    cards.forEach(card => observer.observe(card));
</script>
}
