@model Assignment_NET201.ViewModels.StatisticsViewModel

@{
    ViewData["Title"] = "Thống Kê Doanh Thu";
    Layout = "_AdminLayout";
}

<div class="row g-4 mb-4">
    <!-- Today Orders -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="bg-primary-subtle p-2 rounded-3">
                        <i class="fas fa-shopping-cart text-primary fs-4"></i>
                    </div>
                    <span class="badge @(Model.OrderGrowth >= 0 ? "bg-success" : "bg-danger") rounded-pill">
                        @(Model.OrderGrowth >= 0 ? "+" : "")@Model.OrderGrowth.ToString("N1")%
                    </span>
                </div>
                <h6 class="text-secondary fw-semibold mb-1" style="font-size: 0.85rem;">Đơn Hàng Hôm Nay</h6>
                <h4 class="fw-bold mb-0">@Model.TodayOrders</h4>
            </div>
        </div>
    </div>
    <!-- Today Revenue -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="bg-success-subtle p-2 rounded-3">
                        <i class="fas fa-money-bill-wave text-success fs-4"></i>
                    </div>
                </div>
                <h6 class="text-secondary fw-semibold mb-1" style="font-size: 0.85rem;">Doanh Thu Hôm Nay</h6>
                <h4 class="fw-bold mb-0 text-truncate" title="@Model.TodayRevenue.ToString("N0") VND">
                    @Model.TodayRevenue.ToString("N0") <small class="fw-normal fs-6">VND</small></h4>
            </div>
        </div>
    </div>
    <!-- Monthly Revenue -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="bg-warning-subtle p-2 rounded-3">
                        <i class="fas fa-calendar-check text-warning fs-4"></i>
                    </div>
                    <span class="badge @(Model.RevenueGrowth >= 0 ? "bg-success" : "bg-danger") rounded-pill">
                        @(Model.RevenueGrowth >= 0 ? "+" : "")@Model.RevenueGrowth.ToString("N1")%
                    </span>
                </div>
                <h6 class="text-secondary fw-semibold mb-1" style="font-size: 0.85rem;">Doanh Thu Tháng Hiện Tại</h6>
                <h4 class="fw-bold mb-0 text-truncate" title="@Model.MonthlySales.Values.Last().ToString("N0") VND">
                    @Model.MonthlySales.Values.Last().ToString("N0") <small class="fw-normal fs-6">VND</small></h4>
            </div>
        </div>
    </div>
    <!-- Success Rate -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="bg-info-subtle p-2 rounded-3">
                        <i class="fas fa-check-circle text-info fs-4"></i>
                    </div>
                </div>
                <h6 class="text-secondary fw-semibold mb-1" style="font-size: 0.85rem;">Tỉ Lệ Giao Thành Công</h6>
                @{
                    var total = Model.DeliveredOrdersCount + Model.CancelledOrdersCount + Model.OtherOrdersCount;
                    var rate = total > 0 ? (decimal)Model.DeliveredOrdersCount / total * 100 : 0;
                }
                <h4 class="fw-bold mb-0">@rate.ToString("N1")%</h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue Evolution (Line Chart) -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white py-4 px-4 border-0 pb-0">
                <h5 class="fw-bold mb-0">Biến Động Doanh Thu (30 Ngày Qua)</h5>
            </div>
            <div class="card-body px-3 pb-3">
                <canvas id="dailyRevenueChart" height="250"></canvas>
            </div>
        </div>
    </div>
    <!-- Success/Cancel Ratio (Doughnut Chart) -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white py-4 px-4 border-0 pb-0">
                <h5 class="fw-bold mb-0">Tỉ Lệ Đơn Hàng</h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center p-4">
                <canvas id="orderStatusChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Monthly Comparison (Bar Chart) -->
    <div class="col-lg-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white py-4 px-4 border-0 pb-0">
                <h5 class="fw-bold mb-0">Doanh Thu Theo Tháng (@DateTime.Now.Year)</h5>
            </div>
            <div class="card-body px-3 pb-3">
                <canvas id="monthlySalesChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 overflow-hidden">
    <!-- Top Bestselling Products -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white py-4 px-4 border-0 d-flex justify-content-between align-items-center pb-0">
                <h5 class="fw-bold mb-0">Top 10 Sản Phẩm Bán Chạy</h5>
                <span class="text-muted small">Dựa theo doanh thu</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle table-hover mb-0">
                        <thead class="bg-light small text-uppercase">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th>Danh mục</th>
                                <th class="text-center">Số lượng bán</th>
                                <th class="text-end">Doanh thu</th>
                                <th class="text-end pe-4" style="width: 15%;">Đóng góp (%)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TopProducts)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl" class="rounded me-3 border shadow-sm" width="40"
                                                    height="50" style="object-fit: cover;">
                                            }
                                            <div class="fw-bold">@item.ProductName</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@item.CategoryName</span></td>
                                    <td class="text-center fw-semibold">@item.QuantitySold.ToString("N0")</td>
                                    <td class="text-end fw-bold">@item.Revenue.ToString("N0") VND</td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height: 6px;">
                                                <div class="progress-bar bg-primary" role="progressbar"
                                                    style="width: @item.Percentage.ToString("F1")%"
                                                    aria-valuenow="@item.Percentage" aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                            <span class="small">@item.Percentage.ToString("F1")%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Daily Revenue Chart (Line Chart)
        const dailyCtx = document.getElementById('dailyRevenueChart').getContext('2d');
        new Chart(dailyCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Keys)),
                datasets: [{
                    label: 'Doanh thu (VND)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Values)),
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderWidth: 2,
                    pointBorderColor: '#3b82f6'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { callback: v => v.toLocaleString() + ' đ' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // 2. Order Status Chart (Doughnut)
        const orderCtx = document.getElementById('orderStatusChart').getContext('2d');
        new Chart(orderCtx, {
            type: 'doughnut',
            data: {
                labels: ['Thành công', 'Đã hủy', 'Khác'],
                datasets: [{
                    data: [@Model.DeliveredOrdersCount, @Model.CancelledOrdersCount, @Model.OtherOrdersCount],
                    backgroundColor: ['#10b981', '#ef4444', '#64748b'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                },
                cutout: '70%'
            }
        });

        // 3. Monthly Sales Chart (Bar)
        const monthlyCtx = document.getElementById('monthlySalesChart').getContext('2d');
        new Chart(monthlyCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Keys)),
                datasets: [{
                    label: 'Doanh thu tháng (VND)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Values)),
                    backgroundColor: '#0f172a',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { callback: v => v.toLocaleString() } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}
