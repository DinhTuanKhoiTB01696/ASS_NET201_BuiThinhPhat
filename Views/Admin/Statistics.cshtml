@model Assignment_NET201.ViewModels.StatisticsViewModel

@{
    ViewData["Title"] = "Thống Kê Doanh Thu";
    Layout = "_AdminLayout";
    var total = Model.DeliveredOrdersCount + Model.CancelledOrdersCount + Model.OtherOrdersCount;
    var successRate = total > 0 ? (decimal)Model.DeliveredOrdersCount / total * 100 : 0;
    var thisMonthRevenue = Model.MonthlySales.Values.LastOrDefault();
}

<style>
    .stat-card {
        border: none !important;
        border-radius: 14px !important;
        overflow: hidden;
        color: #fff;
        padding: 1.6rem 1.8rem;
        position: relative;
        min-height: 130px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(0,0,0,0.2); }
    .stat-card::after {
        content: '';
        position: absolute; top: -40px; right: -30px;
        width: 130px; height: 130px; border-radius: 50%;
        background: rgba(255,255,255,0.12);
    }
    .stat-card::before {
        content: '';
        position: absolute; bottom: -50px; right: 30px;
        width: 100px; height: 100px; border-radius: 50%;
        background: rgba(255,255,255,0.08);
    }
    .stat-card .card-icon {
        width: 46px; height: 46px; border-radius: 12px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin-bottom: 0.8rem;
    }
    .stat-card .stat-label { font-size: 0.78rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; opacity: 0.85; }
    .stat-card .stat-value { font-size: 2rem; font-weight: 800; line-height: 1.1; margin: 4px 0 0; }
    .stat-card .stat-value small { font-size: 0.9rem; font-weight: 500; opacity: 0.8; }
    .stat-card .stat-badge {
        display: inline-flex; align-items: center; gap: 4px;
        background: rgba(255,255,255,0.22); border-radius: 20px;
        padding: 3px 10px; font-size: 0.72rem; font-weight: 700;
        position: absolute; top: 1.4rem; right: 1.4rem;
    }

    .bg-grad-purple  { background: linear-gradient(135deg, #7c3aed, #4f46e5); }
    .bg-grad-blue    { background: linear-gradient(135deg, #0ea5e9, #2563eb); }
    .bg-grad-green   { background: linear-gradient(135deg, #10b981, #059669); }
    .bg-grad-orange  { background: linear-gradient(135deg, #f59e0b, #ef4444); }

    /* Chart cards */
    .chart-card {
        background: #fff;
        border: none;
        border-radius: 14px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        overflow: hidden;
    }
    .chart-card .chart-header {
        padding: 1.2rem 1.5rem 0.6rem;
        display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid #f1f5f9;
    }
    .chart-card .chart-header h6 { font-weight: 700; font-size: 0.95rem; margin: 0; color: #0f172a; }
    .chart-card .chart-header .badge-label {
        font-size: 0.72rem; background: #f1f5f9; color: #64748b;
        padding: 3px 10px; border-radius: 20px; font-weight: 600;
    }
    .chart-card .chart-body { padding: 1.2rem 1.5rem 1.5rem; }

    /* Top products */
    .top-product-row {
        display: flex; align-items: center; padding: 0.7rem 1.5rem;
        border-bottom: 1px solid #f8fafc; transition: background 0.2s;
    }
    .top-product-row:hover { background: #f8fafc; }
    .top-product-row:last-child { border-bottom: none; }
    .product-rank {
        width: 28px; height: 28px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem; font-weight: 800; margin-right: 12px; flex-shrink: 0;
    }
    .rank-1 { background: #fef3c7; color: #d97706; }
    .rank-2 { background: #f1f5f9; color: #64748b; }
    .rank-3 { background: #fef2f2; color: #dc2626; }
    .rank-other { background: #f8fafc; color: #94a3b8; }
    .top-product-img {
        width: 42px; height: 48px; object-fit: cover; border-radius: 8px;
        margin-right: 12px; flex-shrink: 0; border: 1px solid #f1f5f9;
    }
    .top-product-name { font-size: 0.85rem; font-weight: 700; color: #0f172a; }
    .top-product-cat { font-size: 0.72rem; color: #94a3b8; margin-top: 2px; }
    .top-product-revenue { font-size: 0.88rem; font-weight: 800; color: #10b981; white-space: nowrap; }
    .top-product-pct { font-size: 0.72rem; color: #94a3b8; }
    .progress-mini { height: 5px; border-radius: 3px; background: #f1f5f9; margin-top: 4px; }
    .progress-mini .bar { height: 100%; border-radius: 3px; }
</style>

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="color:#0f172a;">📊 Thống Kê Doanh Thu</h4>
        <p class="text-muted mb-0" style="font-size:0.85rem;">Cập nhật theo thời gian thực · Năm @DateTime.Now.Year</p>
    </div>
    <a href="/Admin" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
        <i class="fas fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<!-- ===== STAT CARDS ===== -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card bg-grad-purple">
            <div class="card-icon"><i class="fas fa-shopping-bag"></i></div>
            <div class="stat-badge">
                @(Model.OrderGrowth >= 0 ? "▲" : "▼") @Math.Abs(Model.OrderGrowth).ToString("N1")%
            </div>
            <div>
                <div class="stat-label">Số lượng đơn hàng</div>
                <div class="stat-value">@Model.TotalOrders</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card bg-grad-blue">
            <div class="card-icon"><i class="fas fa-money-bill-wave"></i></div>
            <div class="stat-badge">
                @(Model.RevenueGrowth >= 0 ? "▲" : "▼") @Math.Abs(Model.RevenueGrowth).ToString("N1")%
            </div>
            <div>
                <div class="stat-label">Tổng doanh thu</div>
                <div class="stat-value">@((Model.TotalRevenue / 1000000).ToString("N0")) <small>triệu</small></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card bg-grad-green">
            <div class="card-icon"><i class="fas fa-check-double"></i></div>
            <div>
                <div class="stat-label">Thực thu (giao thành công)</div>
                <div class="stat-value">@((Model.CollectedRevenue / 1000000).ToString("N0")) <small>triệu</small></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card bg-grad-orange">
            <div class="card-icon"><i class="fas fa-hourglass-half"></i></div>
            <div>
                <div class="stat-label">Còn phải thu</div>
                <div class="stat-value">@((Model.PendingRevenue / 1000000).ToString("N0")) <small>triệu</small></div>
            </div>
        </div>
    </div>
</div>

<!-- ===== ROW 2: Line Chart + Doughnut + Today ===== -->
<div class="row g-3 mb-4">
    <!-- Daily Line Chart -->
    <div class="col-lg-5">
        <div class="chart-card h-100">
            <div class="chart-header">
                <h6>Doanh Thu 30 Ngày Qua</h6>
                <span class="badge-label">Line Chart</span>
            </div>
            <div class="chart-body">
                <canvas id="dailyRevenueChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <!-- Doughnut: Order Status -->
    <div class="col-lg-3">
        <div class="chart-card h-100">
            <div class="chart-header">
                <h6>Tỉ Lệ Đơn Hàng</h6>
                <span class="badge-label">Donut</span>
            </div>
            <div class="chart-body d-flex flex-column align-items-center">
                <div style="position:relative; width:170px; height:170px;">
                    <canvas id="orderStatusChart"></canvas>
                    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
                        <div style="font-size:1.5rem;font-weight:800;color:#0f172a;">@successRate.ToString("N0")%</div>
                        <div style="font-size:0.65rem;color:#94a3b8;font-weight:600;">Thành công</div>
                    </div>
                </div>
                <div class="mt-3 w-100">
                    <div class="d-flex justify-content-between mb-1" style="font-size:0.75rem;">
                        <span><span style="display:inline-block;width:10px;height:10px;border-radius:3px;background:#10b981;margin-right:5px;"></span>Thành công</span>
                        <strong>@Model.DeliveredOrdersCount</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-1" style="font-size:0.75rem;">
                        <span><span style="display:inline-block;width:10px;height:10px;border-radius:3px;background:#ef4444;margin-right:5px;"></span>Đã hủy</span>
                        <strong>@Model.CancelledOrdersCount</strong>
                    </div>
                    <div class="d-flex justify-content-between" style="font-size:0.75rem;">
                        <span><span style="display:inline-block;width:10px;height:10px;border-radius:3px;background:#94a3b8;margin-right:5px;"></span>Đang xử lý</span>
                        <strong>@Model.OtherOrdersCount</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Today + Month Quick Stats -->
    <div class="col-lg-4">
        <div class="row g-3 h-100">
            <div class="col-12">
                <div class="chart-card" style="padding:1.3rem 1.5rem;">
                    <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Hôm nay</div>
                    <div style="font-size:1.6rem;font-weight:800;color:#0f172a;margin:4px 0;">@Model.TodayOrders <span style="font-size:0.9rem;font-weight:500;color:#64748b;">đơn hàng</span></div>
                    <div style="font-size:1rem;font-weight:700;color:#10b981;">@Model.TodayRevenue.ToString("N0") <span style="font-size:0.8rem;font-weight:500;">VND</span></div>
                </div>
            </div>
            <div class="col-12">
                <div class="chart-card" style="padding:1.3rem 1.5rem;">
                    <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Tháng này (@DateTime.Now.ToString("MM/yyyy"))</div>
                    <div style="font-size:1.6rem;font-weight:800;color:#0f172a;margin:4px 0;">@thisMonthRevenue.ToString("N0")</div>
                    <div style="font-size:0.8rem;color:#64748b;">VND · Tăng trưởng:
                        <strong style="color: @(Model.RevenueGrowth >= 0 ? "#10b981" : "#ef4444")">
                            @(Model.RevenueGrowth >= 0 ? "+" : "")@Model.RevenueGrowth.ToString("N1")%
                        </strong>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="chart-card" style="padding:1.2rem 1.5rem;">
                    <div style="font-size:0.72rem;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Tổng đơn hàng · Tất cả</div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <div style="font-size:1.4rem;font-weight:800;color:#4f46e5;">@Model.TotalOrders</div>
                        <div style="font-size:0.8rem;text-align:right;">
                            <div style="color:#10b981;font-weight:700;">✓ @Model.DeliveredOrdersCount giao</div>
                            <div style="color:#ef4444;font-weight:700;">✕ @Model.CancelledOrdersCount hủy</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== ROW 3: Bar Chart + Category Sales ===== -->
<div class="row g-3 mb-4">
    <!-- Monthly Bar -->
    <div class="col-lg-8">
        <div class="chart-card">
            <div class="chart-header">
                <h6>Doanh Thu Theo Tháng (@DateTime.Now.Year)</h6>
                <span class="badge-label">Bar Chart</span>
            </div>
            <div class="chart-body">
                <canvas id="monthlySalesChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <!-- Category Doughnut -->
    <div class="col-lg-4">
        <div class="chart-card h-100">
            <div class="chart-header">
                <h6>Doanh Thu Theo Danh Mục</h6>
                <span class="badge-label">Pie</span>
            </div>
            <div class="chart-body d-flex align-items-center justify-content-center" style="min-height:220px;">
                <canvas id="categorySalesChart" style="max-height:200px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ===== ROW 4: Top Products ===== -->
<div class="chart-card mb-4">
    <div class="chart-header">
        <h6>🏆 Top Sản Phẩm Bán Chạy</h6>
        <span class="badge-label">Top @Model.TopProducts.Count</span>
    </div>
    @{ int pRank = 0; }
    @foreach (var item in Model.TopProducts)
    {
        pRank++;
        string rankClass = pRank == 1 ? "rank-1" : pRank == 2 ? "rank-2" : pRank == 3 ? "rank-3" : "rank-other";
        <div class="top-product-row">
            <div class="product-rank @rankClass">#@pRank</div>
            @if (!string.IsNullOrEmpty(item.ImageUrl))
            {
                <img src="@item.ImageUrl" class="top-product-img" alt="@item.ProductName">
            }
            else
            {
                <div class="top-product-img bg-light d-flex align-items-center justify-content-center" style="color:#94a3b8;font-size:1.1rem;"><i class="fas fa-box"></i></div>
            }
            <div class="flex-grow-1 me-3">
                <div class="top-product-name">@item.ProductName</div>
                <div class="top-product-cat">@item.CategoryName · @item.QuantitySold.ToString("N0") units</div>
                <div class="progress-mini">
                    <div class="bar" style="width:@item.Percentage.ToString("F1")%; background: linear-gradient(90deg,#4f46e5,#0ea5e9);"></div>
                </div>
            </div>
            <div class="text-end">
                <div class="top-product-revenue">@item.Revenue.ToString("N0")</div>
                <div class="top-product-pct">VND · @item.Percentage.ToString("F1")%</div>
            </div>
        </div>
    }
    @if (!Model.TopProducts.Any())
    {
        <div class="text-center py-5 text-muted" style="font-size:0.9rem;">Chưa có dữ liệu bán hàng</div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const GRAD_BLUE = (ctx) => {
        const g = ctx.createLinearGradient(0, 0, 0, 300);
        g.addColorStop(0, 'rgba(79,70,229,0.25)');
        g.addColorStop(1, 'rgba(79,70,229,0.01)');
        return g;
    };

    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.color = '#94a3b8';

    // 1. Daily Line Chart
    const dailyCtx = document.getElementById('dailyRevenueChart').getContext('2d');
    new Chart(dailyCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Keys)),
            datasets: [{
                label: 'Doanh thu',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySales.Values)),
                borderColor: '#4f46e5',
                backgroundColor: GRAD_BLUE(dailyCtx),
                fill: true, tension: 0.4,
                pointRadius: 3, pointBackgroundColor: '#fff',
                pointBorderWidth: 2, pointBorderColor: '#4f46e5',
                borderWidth: 2.5
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ' ' + ctx.raw.toLocaleString('vi-VN') + ' VND' } } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { callback: v => (v/1000000).toFixed(0) + 'M', font: { size: 11 } } },
                x: { grid: { display: false }, ticks: { font: { size: 10 }, maxTicksLimit: 10 } }
            }
        }
    });

    // 2. Doughnut Order Status
    const orderCtx = document.getElementById('orderStatusChart').getContext('2d');
    new Chart(orderCtx, {
        type: 'doughnut',
        data: {
            labels: ['Thành công', 'Đã hủy', 'Đang xử lý'],
            datasets: [{
                data: [@Model.DeliveredOrdersCount, @Model.CancelledOrdersCount, @Model.OtherOrdersCount],
                backgroundColor: ['#10b981', '#ef4444', '#94a3b8'],
                borderWidth: 0, hoverOffset: 8
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            cutout: '72%'
        }
    });

    // 3. Monthly Bar Chart
    const monthlyCtx = document.getElementById('monthlySalesChart').getContext('2d');
    new Chart(monthlyCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Keys)),
            datasets: [{
                label: 'Doanh thu',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlySales.Values)),
                backgroundColor: (ctx) => {
                    const max = Math.max(...ctx.chart.data.datasets[0].data);
                    return ctx.raw === max ? '#4f46e5' : '#e0e7ff';
                },
                borderRadius: 8, borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => ' ' + ctx.raw.toLocaleString('vi-VN') + ' VND' } }
            },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { callback: v => (v/1000000).toFixed(0) + 'M' } },
                x: { grid: { display: false } }
            }
        }
    });

    // 4. Category Pie Chart
    const catCtx = document.getElementById('categorySalesChart').getContext('2d');
    new Chart(catCtx, {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategorySales.Keys.ToList())),
            datasets: [{
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategorySales.Values.ToList())),
                backgroundColor: ['#4f46e5','#0ea5e9','#10b981','#f59e0b','#ef4444','#8b5cf6'],
                borderWidth: 2, borderColor: '#fff', hoverOffset: 10
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, padding: 12, font: { size: 11 } } },
                tooltip: { callbacks: { label: ctx => ' ' + ctx.raw.toLocaleString('vi-VN') + ' VND' } }
            },
            cutout: '55%'
        }
    });
</script>
}
