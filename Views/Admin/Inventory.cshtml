@model IEnumerable<Assignment_NET201.Models.Product>
@{
    ViewData["Title"] = "Inventory Management";
    Layout = "_AdminLayout";
    var inventoryData = ViewBag.InventoryData as dynamic;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Inventory Management</h3>
    <a asp-action="InventoryHistory" class="btn btn-outline-dark">
        <i class="fas fa-history me-2"></i>Transaction History
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Total Stock</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        var stats = ((IEnumerable<dynamic>)ViewBag.InventoryData).FirstOrDefault(x => x.Product.Id == p.Id);
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                    {
                                        <img src="@p.ImageUrl" class="rounded object-fit-cover me-3" width="48" height="48"
                                            alt="@p.Name">
                                    }
                                    <div class="fw-bold">@p.Name</div>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark border">@p.Category?.Name</span></td>
                            <td>@p.Price.ToString("N0") VND</td>
                            <td>
                                <span class="badge @(stats?.TotalStock > 10 ? "bg-success" : "bg-danger")">
                                    @(stats?.TotalStock ?? 0)
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="ProductVariants" asp-route-productId="@p.Id" class="btn btn-sm btn-dark">
                                    <i class="fas fa-tags me-1"></i> Manage Variants
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
