@model Assignment_NET201.Models.Voucher

@{
    ViewData["Title"] = "Create Voucher";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0">Create New Voucher</h3>
                <a asp-action="Vouchers" class="btn btn-outline-dark rounded-0 px-4">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">
                    <form asp-action="CreateVoucher" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Code" class="form-label small fw-bold text-uppercase">Voucher Code</label>
                                <input asp-for="Code" class="form-control rounded-0" placeholder="e.g. HELOVN" required />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DiscountType" class="form-label small fw-bold text-uppercase">Type</label>
                                <select asp-for="DiscountType" id="discountType" class="form-select rounded-0" required>
                                    <option value="Percentage">Percentage (%)</option>
                                    <option value="FixedAmount">Fixed Amount (VND)</option>
                                </select>
                                <span asp-validation-for="DiscountType" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DiscountValue" class="form-label small fw-bold text-uppercase">Discount Value</label>
                                <div class="input-group">
                                    <input asp-for="DiscountValue" class="form-control rounded-0" type="number" step="0.01" required />
                                    <span class="input-group-text rounded-0" id="discountSuffix">%</span>
                                </div>
                                <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6" id="maxDiscountDiv">
                                <label asp-for="MaxDiscountAmount" class="form-label small fw-bold text-uppercase">Max Discount (VND)</label>
                                <input asp-for="MaxDiscountAmount" class="form-control rounded-0" type="number" step="0.01" />
                                <span asp-validation-for="MaxDiscountAmount" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MinOrderValue" class="form-label small fw-bold text-uppercase">Min Order Value (VND)</label>
                                <input asp-for="MinOrderValue" class="form-control rounded-0" type="number" step="0.01" required />
                                <span asp-validation-for="MinOrderValue" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ExpiryDate" class="form-label small fw-bold text-uppercase">Expiry Date</label>
                                <input asp-for="ExpiryDate" class="form-control rounded-0" type="date" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="UsageLimit" class="form-label small fw-bold text-uppercase">Usage Limit (Total times)</label>
                                <input asp-for="UsageLimit" class="form-control rounded-0" type="number" value="100" required />
                                <span asp-validation-for="UsageLimit" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-4 pt-3 border-top d-grid">
                                <button type="submit" class="btn btn-dark rounded-0 py-3 text-uppercase fw-bold">Create Voucher</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateDiscountUI() {
            var typeSelect = document.getElementById('discountType');
            var maxDiscountDiv = document.getElementById('maxDiscountDiv');
            var discountSuffix = document.getElementById('discountSuffix');
            
            if (typeSelect.value === 'FixedAmount') {
                maxDiscountDiv.classList.add('d-none');
                discountSuffix.textContent = 'VND';
            } else {
                maxDiscountDiv.classList.remove('d-none');
                discountSuffix.textContent = '%';
            }
        }

        document.getElementById('discountType').addEventListener('change', updateDiscountUI);
        
        // Initial check
        updateDiscountUI();
    </script>
}
