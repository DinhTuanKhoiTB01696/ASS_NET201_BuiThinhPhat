@model IEnumerable<Assignment_NET201.Models.Voucher>

@{
    ViewData["Title"] = "Voucher Management";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Manage Vouchers</h3>
    <a asp-action="CreateVoucher" class="btn btn-dark rounded-0 px-4">
        <i class="fas fa-plus me-2"></i>New Voucher
    </a>
</div>

<div class="card border-0 shadow-sm rounded-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light small text-uppercase fw-bold">
                    <tr>
                        <th class="ps-4">Code</th>
                        <th>Type</th>
                        <th>Value</th>
                        <th>Min Order</th>
                        <th>Expiry</th>
                        <th>Usage</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">@item.Code</td>
                            <td>
                                @if (item.DiscountType == "Percentage")
                                {
                                    <span class="badge bg-info-subtle text-info border border-info">Percentage</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary-subtle text-primary border border-primary">Fixed Amount</span>
                                }
                            </td>
                            <td>
                                @if (item.DiscountType == "Percentage")
                                {
                                    <span>@item.DiscountValue%</span>
                                    if (item.MaxDiscountAmount.HasValue)
                                    {
                                        <div class="small text-muted">Max: @item.MaxDiscountAmount.Value.ToString("N0") VND</div>
                                    }
                                }
                                else
                                {
                                    <span>@item.DiscountValue.ToString("N0") VND</span>
                                }
                            </td>
                            <td>@item.MinOrderValue.ToString("N0") VND</td>
                            <td>
                                <span class="@(item.ExpiryDate < DateTime.Now ? "text-danger" : "")">
                                    @item.ExpiryDate.ToString("dd/MM/yyyy")
                                </span>
                            </td>
                            <td>@item.UsedCount / @item.UsageLimit</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="ToggleVoucherStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-secondary" : "btn-outline-success")">
                                        @(item.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
