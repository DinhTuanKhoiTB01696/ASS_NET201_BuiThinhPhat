@model Assignment_NET201.Models.Product

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Edit Product</h5>
                <span class="badge bg-light text-dark border">ID: @Model.Id</span>
            </div>
            <div class="card-body p-4">
                <form asp-action="EditProduct" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <!-- Hidden input to preserve existing ImageUrl if no new file is uploaded -->
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label fw-bold small">Product Name</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold small">Category</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold small">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Price" class="form-label fw-bold small">Price (VND)</label>
                            <input asp-for="Price" class="form-control" type="number" min="0" max="100000000"
                                id="priceInput"
                                oninput="if(this.value > 100000000) this.value = 100000000; if(this.value < 0) this.value = 0;" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                            <div id="priceWarning" class="text-warning small mt-1" style="display:none;">
                                <i class="fas fa-exclamation-triangle me-1"></i> Giá không được vượt quá 100 triệu VNĐ.
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Quantity" class="form-label fw-bold small">Quantity</label>
                            <input asp-for="Quantity" class="form-control" type="number" min="5" max="10000"
                                id="quantityInput"
                                oninput="if(this.value > 10000) this.value = 10000; if(this.value < 0) this.value = 0;" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                            <div id="quantityWarning" class="text-warning small mt-1" style="display:none;">
                                <i class="fas fa-exclamation-triangle me-1"></i> Số lượng nên từ 5 đến 10.000.
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small">Product Image</label>

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ImageUrl" alt="Current Image"
                                        class="rounded border p-1 object-fit-contain" style="height: 100px; width: 100px;">
                                    <small class="text-muted d-block mt-1">Current Image</small>
                                </div>
                            }

                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                            <div class="form-text small">Leave empty to keep current image.</div>
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" role="switch" id="activeStatus"
                            asp-for="IsActive">
                        <label class="form-check-label" for="activeStatus">Active for sale</label>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Products" class="btn btn-light border">Cancel</a>
                        <button type="submit" class="btn btn-dark px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const priceInput = document.getElementById('priceInput');
            const priceWarning = document.getElementById('priceWarning');
            const quantityInput = document.getElementById('quantityInput');
            const quantityWarning = document.getElementById('quantityWarning');

            priceInput.addEventListener('input', function () {
                const val = parseFloat(this.value);
                if (val > 100000000) {
                    priceWarning.style.display = 'block';
                    this.classList.add('is-invalid');
                } else {
                    priceWarning.style.display = 'none';
                    this.classList.remove('is-invalid');
                }
            });

            quantityInput.addEventListener('input', function () {
                const val = parseInt(this.value);
                if (val < 5 || val > 10000) {
                    quantityWarning.style.display = 'block';
                    this.classList.add('is-invalid');
                } else {
                    quantityWarning.style.display = 'none';
                    this.classList.remove('is-invalid');
                }
            });
        });
    </script>
}
