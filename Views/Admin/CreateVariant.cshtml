@model Assignment_NET201.Models.ProductVariant
@{
    ViewData["Title"] = "Add Variant";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0">Add New Variant</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateVariant" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ProductId" value="@ViewBag.ProductId" />

                    <div class="mb-3">
                        <label asp-for="Size" class="form-label">Kích thước</label>
                        <div class="input-group">
                            <select class="form-select" id="sizeSelect" onchange="toggleCustomSize()">
                                <option value="S">S</option>
                                <option value="M">M</option>
                                <option value="L">L</option>
                                <option value="XL">XL</option>
                                <option value="XXL">XXL</option>
                                <option value="38">38</option>
                                <option value="39">39</option>
                                <option value="40">40</option>
                                <option value="41">41</option>
                                <option value="42">42</option>
                                <option value="43">43</option>
                                <option value="Other">Khác (Nhập tay)...</option>
                            </select>
                            <input asp-for="Size" class="form-control" id="customSizeInput" style="display:none;"
                                placeholder="Nhập kích thước..." />
                        </div>
                        <span asp-validation-for="Size" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Color" class="form-label">Màu sắc</label>
                        <div class="input-group">
                            <select class="form-select" id="colorSelect" onchange="toggleCustomColor()">
                                <option value="#FF0000" style="background-color: #FF0000; color: white;">Đỏ</option>
                                <option value="#FF4500" style="background-color: #FF4500; color: white;">Đỏ cam</option>
                                <option value="#FF8C00" style="background-color: #FF8C00; color: white;">Cam</option>
                                <option value="#FFA500" style="background-color: #FFA500; color: black;">Vàng cam
                                </option>
                                <option value="#FFD700" style="background-color: #FFD700; color: black;">Vàng</option>
                                <option value="#9ACD32" style="background-color: #9ACD32; color: black;">Vàng xanh
                                </option>
                                <option value="#008000" style="background-color: #008000; color: white;">Xanh lá
                                </option>
                                <option value="#00FFFF" style="background-color: #00FFFF; color: black;">Xanh lơ
                                </option>
                                <option value="#0000FF" style="background-color: #0000FF; color: white;">Xanh dương
                                </option>
                                <option value="#4B0082" style="background-color: #4B0082; color: white;">Xanh tím
                                </option>
                                <option value="#800080" style="background-color: #800080; color: white;">Tím</option>
                                <option value="#C71585" style="background-color: #C71585; color: white;">Đỏ tím</option>
                                <option value="#000000" style="background-color: #000000; color: white;">Đen</option>
                                <option value="#FFFFFF" style="background-color: #FFFFFF; color: black;">Trắng</option>
                                <option value="#808080" style="background-color: #808080; color: white;">Xám</option>
                                <option value="Other">Khác (Chọn tùy ý)...</option>
                            </select>
                        </div>
                        <div style="position: relative; z-index: 9999;">
                            <input asp-for="Color" type="color" class="form-control form-control-color mt-2"
                                id="customColorInput" style="display:none; max-width: 60px;" title="Chọn màu khác" />
                        </div>
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Hình ảnh biến thể (Tùy chọn)</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Nếu không chọn, sẽ lấy ảnh mặc định của sản phẩm.</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Quantity" class="form-label fw-bold small">Quantity</label>
                                <input asp-for="Quantity" type="number" class="form-control" value="5" min="5"
                                    max="10000" id="quantityInput"
                                    oninput="if(this.value > 10000) this.value = 10000; if(this.value < 0) this.value = 0;" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                                <div id="quantityWarning" class="text-warning small mt-1" style="display:none;">
                                    <i class="fas fa-exclamation-triangle me-1"></i> Số lượng nên từ 5 đến 10.000 sản
                                    phẩm.
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PriceOverride" class="form-label">Price Override (Optional)</label>
                                <input asp-for="PriceOverride" type="number" class="form-control" step="0.01"
                                    max="100000000" id="priceInput"
                                    oninput="if(this.value > 100000000) this.value = 100000000; if(this.value < 0) this.value = 0;" />
                                <span asp-validation-for="PriceOverride" class="text-danger"></span>
                                <div id="priceWarning" class="text-warning small mt-1" style="display:none;">
                                    <i class="fas fa-exclamation-triangle me-1"></i> Giá không được vượt quá 100 triệu
                                    VNĐ.
                                </div>
                                <small class="text-muted">Leave empty to use base price.</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark px-4">Create Variant</button>
                        <a asp-action="ProductVariants" asp-route-productId="@ViewBag.ProductId"
                            class="btn btn-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleCustomSize() {
            var select = document.getElementById("sizeSelect");
            var input = document.getElementById("customSizeInput");
            if (select.value === "Other") {
                input.style.display = "block";
                input.value = "";
                input.focus();
                // We keep the internal asp-for input named 'Size' to submit properly
                input.setAttribute("name", "Size");
                select.removeAttribute("name"); // Don't submit select if input is active
            } else {
                input.style.display = "none";
                input.value = select.value;
                input.removeAttribute("name");
                select.setAttribute("name", "Size"); // Submit select value
            }
        }

        function toggleCustomColor() {
            var select = document.getElementById("colorSelect");
            var input = document.getElementById("customColorInput");
            if (select.value === "Other") {
                input.style.display = "block";
                input.setAttribute("name", "Color");
                select.removeAttribute("name");
            } else {
                input.style.display = "none";
                input.value = select.value;
                input.removeAttribute("name");
                select.setAttribute("name", "Color");
            }
        }

        // Initialize on load
        document.addEventListener("DOMContentLoaded", function () {
            var input = document.getElementById("customSizeInput");
            var select = document.getElementById("sizeSelect");
            // By default, the hidden input shouldn't have the 'name' attribute so the select binds to 'Size'
            input.removeAttribute("name");
            select.setAttribute("name", "Size");

            var colorInput = document.getElementById("customColorInput");
            var colorSelect = document.getElementById("colorSelect");
            colorSelect.setAttribute("name", "Color");

            // Real-time validation warnings
            const quantityInput = document.getElementById('quantityInput');
            const quantityWarning = document.getElementById('quantityWarning');
            const priceInput = document.getElementById('priceInput');
            const priceWarning = document.getElementById('priceWarning');

            quantityInput.addEventListener('input', function () {
                const val = parseInt(this.value);
                if (val < 5 || val > 10000) {
                    quantityWarning.style.display = 'block';
                    this.classList.add('is-invalid');
                } else {
                    quantityWarning.style.display = 'none';
                    this.classList.remove('is-invalid');
                }
            });

            priceInput.addEventListener('input', function () {
                const val = parseFloat(this.value);
                if (val > 100000000) {
                    priceWarning.style.display = 'block';
                    this.classList.add('is-invalid');
                } else {
                    priceWarning.style.display = 'none';
                    this.classList.remove('is-invalid');
                }
            });
        });
    </script>
}
